# Server runtime environment variables
# Copy this file to `.env.local` (or `.env`) before running `npm run dev`.

# Required: Gemini API key used ONLY by server-side `/api/analysis`.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Optional: Override Gemini model for analysis endpoint.
GEMINI_MODEL="gemini-2.5-flash"

# Optional app URL for deployments and callbacks.
APP_URL="http://localhost:3000"

# Optional: LM Studio backup analysis endpoint.
# Used by POST /api/analyze-lmstudio and as an automatic fallback in POST /api/analysis
# when Gemini is unavailable due to region restrictions (FAILED_PRECONDITION).
# Start LM Studio, load a model, and enable the local API server on port 1234.
# LMSTUDIO_URL="http://localhost:1234/api/v1/chat"
# LMSTUDIO_MODEL="qwen3.5-27b-claude-4.6-opus-reasoning-distilled"
